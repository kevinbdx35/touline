---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Page non trouvée - Touline & Co">
  <Navbar />
  <main class="pt-16 flex items-center justify-center min-h-[80vh]">
    <div class="text-center px-4">
      <div class="text-8xl mb-6">⚓</div>
      <h1 class="text-6xl font-bold text-gray-900 mb-4">404</h1>
      <p class="text-xl text-gray-600 mb-8">
        Cette page semble avoir pris le large...
      </p>
      <a
        href={base}
        class="inline-flex items-center gap-2 px-8 py-3 bg-coral text-white rounded-lg hover:bg-coral-dark transition shadow-lg"
      >
        <svg class="w-5 h-5" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" stroke="currentColor">
          <path d="M15 19l-7-7 7-7"></path>
        </svg>
        Retour à l'accueil
      </a>
    </div>
  </main>
  <Footer />
</Layout>
