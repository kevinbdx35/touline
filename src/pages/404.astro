---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Page non trouvée - La Touline">
  <Navbar />
  <main class="pt-16 flex items-center justify-center min-h-[80vh]">
    <div class="text-center px-4">
      <div class="text-8xl mb-6">⚓</div>
      <h1 class="text-6xl font-bold text-gray-900 mb-4">404</h1>
      <p class="text-xl text-gray-600 mb-8">
        Cette page semble avoir pris le large...
      </p>
      <a
        href={base}
        class="inline-flex items-center gap-2 px-8 py-3 bg-coral text-white rounded-lg hover:bg-coral-dark transition shadow-lg"
      >
        <Icon name="lucide:chevron-left" class="w-5 h-5" />
        Retour à l'accueil
      </a>
    </div>
  </main>
  <Footer />
</Layout>
