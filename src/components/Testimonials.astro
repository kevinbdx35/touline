---
const testimonials = [
  {
    name: 'Marie L.',
    location: 'Brest',
    text: "J'ai offert une touline bicolore à mon père marin et il a été ému aux larmes. La qualité du tressage est remarquable, on sent le travail artisanal. Je recommande !",
    rating: 5,
    product: 'Petite Touline Bicolore'
  },
  {
    name: 'Thomas D.',
    location: 'Nantes',
    text: "Parfait comme butoir de porte ! La grosse touline est magnifique, les couleurs sont fidèles aux photos. Livraison rapide et soignée.",
    rating: 5,
    product: 'Touline Géante'
  },
  {
    name: 'Sophie M.',
    location: 'Paris',
    text: "J'ai commandé une touline sur-mesure aux couleurs de la Bretagne. Le résultat est superbe, Appoline a été très à l'écoute. Un vrai savoir-faire !",
    rating: 5,
    product: 'Touline Sur-Mesure'
  },
];
---

<section class="py-20 bg-gradient-to-b from-white to-cream/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16 animate-on-scroll" data-animation="animate-fade-in">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Ce qu'ils en disent
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Nos clients partagent leur expérience avec les toulines artisanales Touline & Co.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
      {testimonials.map((t, i) => (
        <div
          class="bg-white rounded-2xl shadow-lg p-6 sm:p-8 relative animate-on-scroll flex flex-col"
          data-animation="animate-slide-up"
          style={`animation-delay: ${i * 0.15}s`}
        >
          {/* Quote mark */}
          <div class="absolute -top-4 left-6 bg-peach text-primary w-10 h-10 rounded-full flex items-center justify-center text-2xl font-serif shadow-md">
            "
          </div>

          {/* Stars */}
          <div class="flex gap-1 mb-4 mt-2">
            {Array.from({ length: t.rating }).map((_, j) => (
              <svg class="w-5 h-5 text-peach" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          {/* Text */}
          <p class="text-gray-600 leading-relaxed mb-6 flex-1 italic">
            "{t.text}"
          </p>

          {/* Author */}
          <div class="border-t border-gray-100 pt-4 flex items-center justify-between gap-3">
            <div class="flex-shrink-0">
              <div class="font-semibold text-gray-900">{t.name}</div>
              <div class="text-sm text-gray-500">{t.location}</div>
            </div>
            <div class="text-xs bg-cream text-primary px-3 py-1 rounded-full font-medium whitespace-nowrap flex-shrink-0">
              {t.product}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
