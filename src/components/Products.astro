---
import { categories } from '../data/products.js';
import ProductCard from './ProductCard.jsx';

const base = import.meta.env.BASE_URL;

// Prefix image paths with base URL so they resolve correctly
const categoriesWithBase = categories.map((cat) => ({
  ...cat,
  images: cat.images.map((img) => `${base}${img}`),
}));
---

<section id="produits" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-3 sm:mb-4 px-2">
        Nos Créations
      </h2>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto mb-4 sm:mb-6 px-4">
        Découvrez notre collection de toulines artisanales, chacune confectionnée avec soin et passion
      </p>
      <div class="max-w-3xl mx-auto bg-green-50 border border-green-200 rounded-xl p-3 sm:p-4 mx-4">
        <p class="text-xs sm:text-sm text-green-900 text-left sm:text-center">
          <span class="font-semibold">✓ Stock permanent :</span> Toutes nos tailles sont disponibles en stock. Les couleurs peuvent varier selon nos arrivages,
          mais nous pouvons également fabriquer votre touline sur commande avec les couleurs de votre choix.
        </p>
      </div>
    </div>

    <!-- Categories Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {categoriesWithBase.map((category, index) => (
        <ProductCard
          client:visible
          category={category}
          isNew={category.isNew}
          index={index}
        />
      ))}
    </div>
  </div>
</section>
