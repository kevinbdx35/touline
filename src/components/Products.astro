---
import { categories } from '../data/products.js';
import ProductCard from './ProductCard.jsx';

const base = import.meta.env.BASE_URL;

// Prefix image paths with base URL so they resolve correctly
const categoriesWithBase = categories.map((cat) => ({
  ...cat,
  images: cat.images.map((img) => `${base}${img}`),
}));
---

<section id="produits" class="py-20 bg-gray-50/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16 animate-on-scroll" data-animation="animate-fade-in">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-3 sm:mb-4">
        Nos Créations
      </h2>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto mb-6">
        Découvrez notre collection de toulines artisanales, chacune confectionnée avec soin et passion
      </p>
      <div class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-full px-5 py-2.5 text-sm text-gray-600 shadow-sm">
        <span class="w-2 h-2 bg-green-400 rounded-full"></span>
        <span><strong class="text-gray-900">Stock permanent</strong> — Couleurs personnalisables sur commande</span>
      </div>
    </div>

    <!-- Categories Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {categoriesWithBase.map((category, index) => (
        <ProductCard
          client:visible
          category={category}
          isNew={category.isNew}
          index={index}
        />
      ))}
    </div>
  </div>
</section>
