---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="bg-gray-900 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- About -->
      <div>
        <h3 class="text-2xl font-bold mb-4">Touline & Co</h3>
        <p class="text-gray-400">
          Artisan créateur de toulines marines depuis plus de 10 ans.
          Chaque pièce est unique et fabriquée à la main en Bretagne avec passion.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-semibold mb-4">Liens rapides</h4>
        <ul class="space-y-2">
          <li>
            <a href={`${base}#accueil`} class="text-gray-400 hover:text-peach transition">
              Accueil
            </a>
          </li>
          <li>
            <a href={`${base}#produits`} class="text-gray-400 hover:text-peach transition">
              Produits
            </a>
          </li>
          <li>
            <a href={`${base}#savoir-faire`} class="text-gray-400 hover:text-peach transition">
              Savoir-faire
            </a>
          </li>
          <li>
            <a href={`${base}#contact`} class="text-gray-400 hover:text-peach transition">
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-lg font-semibold mb-4">Informations légales</h4>
        <ul class="space-y-2">
          <li>
            <a href={`${base}mentions-legales/`} class="text-gray-400 hover:text-peach transition">
              Mentions légales
            </a>
          </li>
          <li>
            <a href={`${base}cgv/`} class="text-gray-400 hover:text-peach transition">
              CGV
            </a>
          </li>
          <li>
            <a href={`${base}politique-confidentialite/`} class="text-gray-400 hover:text-peach transition">
              Politique de confidentialité
            </a>
          </li>
          <li>
            <a href={`${base}livraison-retours/`} class="text-gray-400 hover:text-peach transition">
              Livraison & Retours
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 text-center">
      <p class="text-gray-400">
        &copy; {currentYear} Touline & Co. Tous droits réservés. Fait avec passion ⚓
      </p>
    </div>
  </div>
</footer>
