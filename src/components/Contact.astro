---
import EmailLink from './EmailLink.jsx';
const base = import.meta.env.BASE_URL;
---

<section id="contact" class="py-20 bg-gradient-to-b from-white to-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Contactez-nous
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Une question, une commande personnalisée ou simplement envie d'échanger ? N'hésitez pas à nous contacter !
      </p>
    </div>

    <div class="max-w-2xl mx-auto">
      <div class="bg-white rounded-2xl shadow-xl p-6 sm:p-8 md:p-12 text-center">
        <img src={`${base}img_2/recto_c_v.webp`} alt="Carte de visite La Touline" class="w-full max-w-md mx-auto rounded-xl mb-6 sm:mb-8" />
        <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3 sm:mb-4">Email</h3>
        <EmailLink client:load className="text-base sm:text-2xl md:text-3xl text-primary hover:text-secondary transition font-semibold break-words" />
      </div>
    </div>
  </div>
</section>
