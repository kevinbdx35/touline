---
import EmailLink from './EmailLink.jsx';
const base = import.meta.env.BASE_URL;
---

<section id="contact" class="py-20 bg-gradient-to-b from-white to-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Contactez-nous
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Une question, une commande personnalisée ou simplement envie d'échanger ? N'hésitez pas à nous contacter !
      </p>
    </div>

    <div class="max-w-3xl mx-auto">
      <!-- Carte de visite -->
      <div class="rounded-2xl shadow-xl overflow-hidden flex flex-col sm:flex-row" role="img" aria-label="Carte de visite La Touline">
        <!-- Panneau gauche -->
        <div class="bg-coral flex flex-col items-center justify-center px-8 py-10 sm:py-12 sm:w-2/5">
          <!-- Logo soleil + vagues -->
          <svg viewBox="0 0 120 100" class="w-28 h-24 mb-6" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Rayons -->
            <line x1="60" y1="8" x2="60" y2="0" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="78" y1="12" x2="84" y2="4" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="90" y1="24" x2="98" y2="20" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="42" y1="12" x2="36" y2="4" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="30" y1="24" x2="22" y2="20" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            <!-- Demi-soleil -->
            <path d="M 35 55 A 25 25 0 0 1 85 55" fill="white"/>
            <!-- Vagues -->
            <path d="M 20 62 Q 35 52, 50 62 Q 65 72, 80 62 Q 95 52, 105 62" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <path d="M 20 72 Q 35 62, 50 72 Q 65 82, 80 72 Q 95 62, 105 72" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <path d="M 20 82 Q 35 72, 50 82 Q 65 92, 80 82 Q 95 72, 105 82" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          </svg>
          <p class="text-white text-2xl font-serif italic mb-2">La Touline</p>
          <p class="text-white/80 text-sm">Boutique de portes-clés</p>
        </div>

        <!-- Panneau droit -->
        <div class="bg-white flex flex-col justify-center px-8 py-10 sm:py-12 sm:w-3/5 gap-6">
          <!-- Email -->
          <div class="flex items-center gap-4">
            <svg class="w-7 h-7 text-coral shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            <EmailLink client:load className="text-lg sm:text-xl font-semibold text-coral hover:text-coral-dark transition break-all" />
          </div>

          <!-- Site web -->
          <a href="https://kevinbdx35.github.io/touline/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
            <svg class="w-7 h-7 text-coral shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A8.966 8.966 0 0 1 3 12c0-1.264.26-2.466.732-3.558"/>
            </svg>
            <span class="text-lg sm:text-xl font-semibold text-coral group-hover:text-coral-dark transition">kevinbdx35.github.io/touline/</span>
          </a>

          <!-- Adresse -->
          <div class="flex items-start gap-4">
            <svg class="w-7 h-7 text-coral shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
            <div>
              <p class="text-lg sm:text-xl font-semibold text-coral">23 Avenue de l'Atlantique</p>
              <p class="text-lg sm:text-xl font-semibold text-coral">56510 St Pierre Quiberon</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
