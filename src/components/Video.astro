---
const base = import.meta.env.BASE_URL;
---

<section id="video" class="py-20 bg-gradient-to-b from-cream/50 to-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Découvrez nos toulines
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Un aperçu de notre savoir-faire et de nos créations artisanales.
      </p>
    </div>

    <div class="rounded-2xl shadow-xl overflow-hidden">
      <video
        controls
        preload="metadata"
        class="w-full aspect-video bg-gray-900"
        poster=""
      >
        <source src={`${base}video/presentation-touline.mp4`} type="video/mp4" />
        Votre navigateur ne supporte pas la lecture de vidéos.
      </video>
    </div>
  </div>
</section>
