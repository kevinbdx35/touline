---
import { Icon } from 'astro-icon/components';
const base = import.meta.env.BASE_URL;

const navLinks = [
  { href: '#accueil', label: 'Accueil' },
  { href: '#produits', label: 'Produits' },
  { href: '#savoir-faire', label: 'Savoir-faire' },
  { href: '#contact', label: 'Contact' },
];
---

<!-- Promo banner -->
<div id="promo-banner" class="fixed w-full z-50 bg-gradient-to-r from-coral to-coral-dark text-white text-center text-xs sm:text-sm py-1.5 sm:py-2 px-4 transition-all duration-300">
  <div class="max-w-7xl mx-auto flex items-center justify-center gap-2">
    <span>Livraison offerte en France métropolitaine</span>
    <button id="close-promo" class="ml-1 sm:ml-2 text-white/70 hover:text-white transition p-1" aria-label="Fermer le bandeau">
      <Icon name="lucide:x" class="w-4 h-4" />
    </button>
  </div>
</div>

<nav id="main-nav" class="fixed w-full bg-white/95 backdrop-blur-sm shadow-sm z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex-shrink-0 flex items-center">
        <a href={base} class="text-2xl font-bold text-primary">Touline & Co</a>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex space-x-8">
        {navLinks.map(({ href, label }) => (
          <a
            href={`${base}${href}`}
            class="nav-link text-gray-700 hover:text-primary transition relative py-1"
            data-section={href.replace('#', '')}
          >
            {label}
            <span class="nav-indicator absolute bottom-0 left-0 w-full h-0.5 bg-primary scale-x-0 transition-transform duration-300 origin-center" />
          </a>
        ))}
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          id="mobile-menu-btn"
          class="text-gray-700 hover:text-primary focus:outline-none focus:ring-2 focus:ring-secondary focus:ring-offset-2 rounded-md p-2"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="h-6 w-6" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path id="menu-icon-open" d="M4 6h16M4 12h16M4 18h16"></path>
            <path id="menu-icon-close" d="M6 18L18 6M6 6l12 12" class="hidden"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden bg-white border-t hidden">
    <div class="px-3 pt-2 pb-4 space-y-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={`${base}${href}`}
          class="mobile-nav-link block w-full text-left px-4 py-3 text-base text-gray-700 hover:bg-cream hover:text-primary rounded-lg transition-colors"
          data-section={href.replace('#', '')}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  function initNavbar() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');
    const nav = document.getElementById('main-nav');

    if (!btn || !menu || !iconOpen || !iconClose) return;

    // Mobile menu toggle
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
      btn.setAttribute('aria-label', isOpen ? 'Ouvrir le menu' : 'Fermer le menu');
    });

    // Close menu when clicking a mobile nav link
    menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Ouvrir le menu');
      });
    });

    // Promo banner
    const promoBanner = document.getElementById('promo-banner');
    const closePromo = document.getElementById('close-promo');

    if (promoBanner && nav) {
      // Set initial nav offset to match actual banner height
      const updateNavOffset = () => {
        const bannerHeight = promoBanner.getBoundingClientRect().height;
        nav.style.top = `${bannerHeight}px`;
      };
      updateNavOffset();
      window.addEventListener('resize', updateNavOffset);

      if (closePromo) {
        closePromo.addEventListener('click', () => {
          promoBanner.style.transform = 'translateY(-100%)';
          nav.style.top = '0';
        });
      }
    }

    // Navbar scroll shadow effect
    if (nav) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          nav.classList.replace('shadow-sm', 'shadow-lg');
          nav.classList.replace('bg-white/95', 'bg-white');
        } else {
          nav.classList.replace('shadow-lg', 'shadow-sm');
          nav.classList.replace('bg-white', 'bg-white/95');
        }
      }, { passive: true });
    }

    // Active section highlighting
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');

    if (sections.length === 0) return;

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;

            navLinks.forEach((link) => {
              const indicator = link.querySelector('.nav-indicator');
              if (link.dataset.section === id) {
                link.classList.replace('text-gray-700', 'text-primary');
                if (indicator) indicator.classList.replace('scale-x-0', 'scale-x-100');
              } else {
                link.classList.replace('text-primary', 'text-gray-700');
                if (indicator) indicator.classList.replace('scale-x-100', 'scale-x-0');
              }
            });

            mobileLinks.forEach((link) => {
              if (link.dataset.section === id) {
                link.classList.add('bg-cream', 'text-primary', 'font-semibold');
              } else {
                link.classList.remove('bg-cream', 'text-primary', 'font-semibold');
              }
            });
          }
        });
      },
      {
        threshold: 0.3,
        rootMargin: '-80px 0px -50% 0px',
      }
    );

    sections.forEach((section) => sectionObserver.observe(section));
  }

  initNavbar();
  document.addEventListener('astro:page-load', initNavbar);
</script>
