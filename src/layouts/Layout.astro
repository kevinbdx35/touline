---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Touline & Co - Toulines Artisanales Fait Main | Décoration Maritime",
  description = "Découvrez nos toulines artisanales confectionnées à la main selon les traditions maritimes. Monocolor, Bicolor, Tricolor - Créations uniques et personnalisables. Livraison en France.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="touline, touline artisanale, touline fait main, décoration maritime, noeud marin, artisanat français, touline personnalisée, décoration nautique, butoir de porte maritime" />
    <meta name="author" content="Touline & Co" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://votre-domaine.fr/" />
    <meta property="og:title" content="Touline & Co - Toulines Artisanales Fait Main" />
    <meta property="og:description" content="Créations uniques tissées avec passion. Chaque touline est confectionnée à la main selon les traditions maritimes ancestrales." />
    <meta property="og:image" content="https://votre-domaine.fr/img/monocolor.webp" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Touline & Co" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://votre-domaine.fr/" />
    <meta property="twitter:title" content="Touline & Co - Toulines Artisanales Fait Main" />
    <meta property="twitter:description" content="Créations uniques tissées avec passion. Chaque touline est confectionnée à la main selon les traditions maritimes ancestrales." />
    <meta property="twitter:image" content="https://votre-domaine.fr/img/monocolor.webp" />

    <!-- Additional SEO -->
    <meta name="theme-color" content="#2563eb" />
    <link rel="canonical" href="https://votre-domaine.fr/" />
  </head>
  <body class="min-h-screen">
    <slot />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </body>
</html>
