---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Touline & Co - Toulines Artisanales Fait Main | Décoration Maritime",
  description = "Découvrez nos toulines artisanales confectionnées à la main selon les traditions maritimes. Monocolor, Bicolor, Tricolor - Créations uniques et personnalisables. Livraison en France.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteUrl = "https://kevinbdx35.github.io/touline";
const currentUrl = `${siteUrl}${Astro.url.pathname.replace(base, '/')}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Touline & Co",
  "description": "Artisan créateur de toulines marines artisanales fait main en Bretagne. Décoration maritime unique et personnalisable.",
  "url": siteUrl,
  "image": `${siteUrl}/img/monocolor.webp`,
  "email": "touline_co@proton.me",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "FR"
  },
  "priceRange": "€",
  "paymentAccepted": "Virement, PayPal",
  "areaServed": {
    "@type": "Country",
    "name": "France"
  },
  "sameAs": []
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="touline, touline artisanale, touline fait main, décoration maritime, noeud marin, artisanat français, touline personnalisée, décoration nautique, butoir de porte maritime" />
    <meta name="author" content="Touline & Co" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content="Touline & Co - Toulines Artisanales Fait Main" />
    <meta property="og:description" content="Créations uniques tissées avec passion. Chaque touline est confectionnée à la main selon les traditions maritimes ancestrales." />
    <meta property="og:image" content={`${siteUrl}/img/monocolor.webp`} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Touline & Co" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={currentUrl} />
    <meta property="twitter:title" content="Touline & Co - Toulines Artisanales Fait Main" />
    <meta property="twitter:description" content="Créations uniques tissées avec passion. Chaque touline est confectionnée à la main selon les traditions maritimes ancestrales." />
    <meta property="twitter:image" content={`${siteUrl}/img/monocolor.webp`} />

    <!-- Additional SEO -->
    <meta name="theme-color" content="#0081A7" />
    <link rel="canonical" href={currentUrl} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- View Transitions -->
    <ViewTransitions />
  </head>
  <body class="min-h-screen">
    <a href="#contenu-principal" class="skip-to-content bg-primary text-white font-semibold shadow-lg">
      Aller au contenu principal
    </a>
    <slot />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </body>
</html>
