---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout title={`${title} - Touline & Co`} description={title}>
  <Navbar />
  <main class="pt-16">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <a
        href={base}
        class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 transition mb-8 group"
      >
        <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" stroke="currentColor">
          <path d="M15 19l-7-7 7-7"></path>
        </svg>
        Retour à l'accueil
      </a>
      <slot />
    </div>
  </main>
  <Footer />
</Layout>
